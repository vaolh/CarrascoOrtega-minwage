. *************************************************
. ***** DiD: Wages by Indigenous Identity *********
. *************************************************
. 
. foreach ds in year month {
  2. 
. do read-enigh`ds'.do
  3. estimates clear
  4. 
. * All units — no controls
. reghdfe lnw i.zlfn##i.post, absorb(ubica_geo year) vce(cluster ubica_geo)
  5.      eststo t1m1
  6.      estadd local controls       "N"
  7.      estadd local hastimefe      "Y"
  8.      estadd local hasmunicfe     "Y"
  9. 
. * All units — with controls
. reghdfe lnw i.zlfn##i.post $controls, absorb(ubica_geo year) vce(cluster ubic
> a_geo)
 10.      eststo t1m2
 11.      estadd local controls       "Y"
 12.      estadd local hastimefe      "Y"
 13.      estadd local hasmunicfe     "Y"
 14. 
. * Non-indigenous (self-identified) — no controls
. reghdfe lnw i.zlfn##i.post if etnia == 0, absorb(ubica_geo year) vce(cluster 
> ubica_geo)
 15.      eststo t1m3
 16.      estadd local controls       "N"
 17.      estadd local hastimefe      "Y"
 18.      estadd local hasmunicfe     "Y"
 19. 
. * Non-indigenous (self-identified) — with controls
. reghdfe lnw i.zlfn##i.post $controls if etnia == 0, absorb(ubica_geo year) vc
> e(cluster ubica_geo)
 20.      eststo t1m4
 21.      estadd local controls       "Y"
 22.      estadd local hastimefe      "Y"
 23.      estadd local hasmunicfe     "Y"
 24. 
. * Indigenous (self-identified) — no controls
. reghdfe lnw i.zlfn##i.post if etnia == 1, absorb(ubica_geo year) vce(cluster 
> ubica_geo)
 25.      eststo t1m5
 26.      estadd local controls       "N"
 27.      estadd local hastimefe      "Y"
 28.      estadd local hasmunicfe     "Y"
 29. 
. * Indigenous (self-identified) — with controls
. reghdfe lnw i.zlfn##i.post $controls if etnia == 1, absorb(ubica_geo year) vc
> e(cluster ubica_geo)
 30.      eststo t1m6
 31.      estadd local controls       "Y"
 32.      estadd local hastimefe      "Y"
 33.      estadd local hasmunicfe     "Y"
 34. 
. *************************************************
. *************** Export TeX Table ****************
. *************************************************
. 
. esttab t1m1 t1m2 t1m3 t1m4 t1m5 t1m6 ///
>     using "../../paper/tables/did-wage-indig-`ds'.tex", replace label fragmen
> t ///
>     nolines posthead(\cmidrule{2-7}) prefoot(\midrule) ///
>     postfoot(\bottomrule \bottomrule) booktabs ///
>     nonumbers mtitle("(1)" "(2)" "(3)" "(4)" "(5)" "(6)") collabels(none) ///
>     cells(b(star fmt(%9.3f)) se(par fmt(%9.3f))) ///
>     starlevels(* 0.10 ** 0.05 *** 0.01) ///
>     refcat(1.zlfn#1.post "ZLFN $\times$", nolabel) ///
>     keep(1.zlfn#1.post) ///
>     coeflabel(1.zlfn#1.post "{2016-2024}") ///
>     stats(N controls hastimefe hasmunicfe, ///
>         fmt(%11.0gc) label("Observations" "Controls" "Time FE" "Municipal FE"
> )) onecell
 35. }

. *************************************************
. *************** Read ENIGH Year *****************
. *************************************************
. 
. *** REPLICATION FILE: read-enighyear
. *** STATA VERSION: StataNow 19.5
. *** AUTHORS: Matías Carrasco, Victor Ortega Le Hénanff
. *** DATE: 2026-03-03
. 
. *  Loads the yearly cross-section produced by
. *  data/clean/code/enigh-year.R, generates derived
. *  variables and sets the $controls global.
. 
. *  Called by every analysis do-file:
. *     do read-enighyear.do
. 
. *************************************************
. ****************** Load Data ********************
. *************************************************
. 
. use "../../data/clean/enigh/enigh-year.dta", clear

. 
. ssc install require, replace
checking require consistency and verifying not already installed...
all files already exist and are up to date.

. ssc install estout, replace
checking estout consistency and verifying not already installed...
all files already exist and are up to date.

. ssc install coefplot, replace
checking coefplot consistency and verifying not already installed...
all files already exist and are up to date.

. 
. * Install ftools (remove program if it existed previously)
. net install ftools, replace from("https://raw.githubusercontent.com/sergiocor
> reia/ftools/master/src/")
checking ftools consistency and verifying not already installed...
all files already exist and are up to date.

. 
. * Install reghdfe 6.x
. net install reghdfe, replace from("https://raw.githubusercontent.com/sergioco
> rreia/reghdfe/master/src/")
checking reghdfe consistency and verifying not already installed...
all files already exist and are up to date.

. 
. *************************************************
. *************** Decode Factors ******************
. *************************************************
. 
. * haven::write_dta stores R factors as labeled integers.
. * Decode year and ent to recover original numeric values.
. 
. foreach v in year ent {
  2.     capture decode `v', gen(_`v'_str)
  3.     if _rc == 0 {
  4.         destring _`v'_str, replace force
  5.         drop `v'
  6.         rename _`v'_str `v'
  7.     }
  8. }

. 
. *************************************************
. *********** Generate Log Incomes ****************
. *************************************************
. 
. gen lnw   = ln(ing_wages)            if ing_wages > 0
(206,957 missing values generated)

. gen lni   = ln(ing_lab)              if ing_lab > 0
(42,758 missing values generated)

. gen lnmon = ln(ing_mon)              if ing_mon > 0
(24,777 missing values generated)

. gen lnr   = ln(ing_rentas)          if ing_rentas > 0
(682,670 missing values generated)

. gen lnv   = ln(ing_ventas)          if ing_ventas > 0
(676,733 missing values generated)

. gen lno   = ln(ing_other)           if ing_other > 0
(565,544 missing values generated)

. gen lnn   = ln(ing_negocio)         if ing_negocio > 0
(546,587 missing values generated)

. gen lnnwi = ln(ing_non_wage_income) if ing_non_wage_income > 0
(523,909 missing values generated)

. gen lngt  = ln(ing_gov_transfers)   if ing_gov_transfers > 0
(583,326 missing values generated)

. gen lnfc  = ln(ing_fin_capital)     if ing_fin_capital > 0
(663,912 missing values generated)

. 
. *************************************************
. ************ Derived Variables ******************
. *************************************************
. 
. gen female = 1 - sexo

. gen edadsq = edad_pob * edad_pob

. 
. label variable lnw   "Log Wages"

. label variable lni   "Log Labor Income"

. label variable lnmon "Log Monetary Income"

. label variable lnr   "Log Rent Income"

. label variable lnv   "Log Sales Income"

. label variable lno   "Log Other Income"

. label variable lnn   "Log Business Income"

. label variable lnnwi "Log Non-Wage Income"

. label variable lngt  "Log Government Transfers"

. label variable lnfc  "Log Financial Capital Income"

. label variable post  "Post-Treatment (year > 2018)"

. label variable female "Female"

. label variable edadsq "Age Squared"

. 
. *************************************************
. ***************** Controls **********************
. *************************************************
. 
. global controls i.female edad_pob edadsq years_of_study hoursworked i.employe
> d

. 
end of do-file
