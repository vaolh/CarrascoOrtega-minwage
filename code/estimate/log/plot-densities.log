. 
. *** ZLFN daily MW (2019) × 30 days, log scale
. *** Adjust this value if wages are deflated to a different base
. local mw_zlfn = ln(176.72 * 30)

. 
. twoway (kdensity lnw if post == 0 & indspeaker == 0, bw(0.3) lcolor(blue) lpa
