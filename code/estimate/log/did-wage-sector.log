. *************************************************
. *** DiD: Sector Heterogeneity *******************
. **** Panel A: Pre-treatment sector shares *******
. **** Panel B: DiD by sector coverage ************
. *************************************************
. 
. foreach ds in year month {
  2. 
. do read-enigh`ds'.do
  3. estimates clear
  4. 
. *************************************************
. ************ Harmonize Sector Variable **********
. *************************************************
. 
. *** Year data has `sector'; month data has `ind1'
. if "`ds'" == "month" {
  5.     cap gen sector = ind1
  6.     cap gen informal = (sar_afore1 != 1) if employed == 1
  7. }
  8. 
. *** Covered = sectors with MW enforcement
. *** Uncovered = agriculture (11), other services incl. domestic (81),
. ***             unspecified workers (97, 99)
. gen covered = !inlist(sector, 11, 81, 97, 99) if !missing(sector)
  9. 
. *************************************************
. *** Panel A: Pre-treatment Sector Shares ********
. *************************************************
. 
. *** Sector distribution before treatment (year <= 2018)
. *** By ethnicity (indspeaker)
. 
. eststo share_all: quietly estpost tabulate sector if post == 0, nototal
 10. eststo share_nonind: quietly estpost tabulate sector if post == 0 & indspe
> aker == 0, nototal
 11. eststo share_ind: quietly estpost tabulate sector if post == 0 & indspeake
> r == 1, nototal
 12. 
. esttab share_all share_nonind share_ind ///
>     using "../../paper/tables/sum-sector-shares-`ds'.tex", replace label frag
> ment ///
>     nolines posthead(\cmidrule{2-4}) prefoot(\midrule) ///
>     postfoot(\bottomrule \bottomrule) booktabs ///
>     nonumbers mtitle("(1)" "(2)" "(3)") collabels(none) ///
>     cells(pct(fmt(%9.1f))) ///
>     stats(N, fmt(%11.0gc) label("Observations")) onecell
 13. 
. *************************************************
. *** Panel B: DiD by Coverage × Ethnicity ********
. **** Covered sectors ****************************
. *************************************************
. 
. estimates clear
 14. 
. *** All — covered
. reghdfe lnw i.zlfn##i.post $controls if covered == 1, absorb(ubica_geo year) 
> vce(cluster ubica_geo)
 15.      eststo c1
 16.      estadd local controls   "Y"
 17.      estadd local hastimefe  "Y"
 18.      estadd local hasmunicfe "Y"
 19. 
. *** Non-ind speakers — covered
. reghdfe lnw i.zlfn##i.post $controls if covered == 1 & indspeaker == 0, absor
> b(ubica_geo year) vce(cluster ubica_geo)
 20.      eststo c2
 21.      estadd local controls   "Y"
 22.      estadd local hastimefe  "Y"
 23.      estadd local hasmunicfe "Y"
 24. 
. *** Non-ind self-id — covered
. reghdfe lnw i.zlfn##i.post $controls if covered == 1 & etnia == 0, absorb(ubi
> ca_geo year) vce(cluster ubica_geo)
 25.      eststo c3
 26.      estadd local controls   "Y"
 27.      estadd local hastimefe  "Y"
 28.      estadd local hasmunicfe "Y"
 29. 
. *** Ind speakers — covered
. reghdfe lnw i.zlfn##i.post $controls if covered == 1 & indspeaker == 1, absor
> b(ubica_geo year) vce(cluster ubica_geo)
 30.      eststo c4
 31.      estadd local controls   "Y"
 32.      estadd local hastimefe  "Y"
 33.      estadd local hasmunicfe "Y"
 34. 
. *** Ind self-id — covered
. reghdfe lnw i.zlfn##i.post $controls if covered == 1 & etnia == 1, absorb(ubi
> ca_geo year) vce(cluster ubica_geo)
